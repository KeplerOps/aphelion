# Architecture Test: Kernel Boundary (ADR-002)
#
# Rule: Modules in src/domain/ and src/api/ must not import from
#        src/infrastructure/engine/ (the Kuzu kernel adapter layer).
#
# Rationale: ADR-002 requires the product architecture to own system boundaries.
#            The kernel is an internal subsystem. Domain and API layers interact
#            with the kernel only through product-defined interfaces.
#
# See: docs/adr-enforcement.md, docs/adrs/ADR-002.md

# Pseudocode — convert to chosen framework when tech stack is selected.

def test_domain_does_not_import_kernel():
    """
    Scan all modules under src/domain/ and verify that none of them
    import from src/infrastructure/engine/ or reference kernel types.
    """
    domain_modules = find_all_modules("src/domain/")
    for module in domain_modules:
        imports = get_imports(module)
        for imp in imports:
            assert not imp.starts_with("infrastructure.engine"), (
                f"{module} imports {imp} — domain must not depend on kernel. "
                f"Use a product-defined interface instead. (ADR-002)"
            )

def test_api_does_not_import_kernel():
    """
    Scan all modules under src/api/ and verify that none of them
    import from src/infrastructure/engine/ or reference kernel types.
    """
    api_modules = find_all_modules("src/api/")
    for module in api_modules:
        imports = get_imports(module)
        for imp in imports:
            assert not imp.starts_with("infrastructure.engine"), (
                f"{module} imports {imp} — api must not depend on kernel. "
                f"Use a product-defined interface instead. (ADR-002)"
            )

def test_kernel_types_not_in_public_signatures():
    """
    Scan all public functions/methods in src/api/ and verify their
    parameter types and return types do not reference kernel types.
    """
    api_functions = find_public_functions("src/api/")
    kernel_types = find_exported_types("src/infrastructure/engine/")
    for func in api_functions:
        for param_type in func.parameter_types + [func.return_type]:
            assert param_type not in kernel_types, (
                f"{func.qualified_name} uses kernel type {param_type} "
                f"in its signature — public APIs must not expose kernel types. (ADR-002, ADR-007)"
            )
