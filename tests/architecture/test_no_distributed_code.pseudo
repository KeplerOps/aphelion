# Architecture Test: No Distributed Code in V1 (ADR-003, ADR-005)
#
# Rule: No module outside a feature-gated clustering module may define or use
#        distributed transaction, consensus, replication, or cross-node types.
#
# Rationale: ADR-003 commits v1 to single-node operation. ADR-005 preserves
#            single-node local storage and transactions. Distributed code is
#            out of scope until a future ADR selects a specific mechanism.
#
# See: docs/adr-enforcement.md, docs/adrs/ADR-003.md, docs/adrs/ADR-005.md

# Pseudocode — convert to chosen framework when tech stack is selected.

DISTRIBUTED_TYPE_PATTERNS = [
    "RaftConsensus", "PaxosConsensus", "LeaderElection", "QuorumVote",
    "TwoPhaseCommit", "DistributedTransaction", "LogShipper",
    "MultiPrimary", "ClusterCoordinator", "NodeDiscovery",
    "ConsensusProtocol", "ReplicationManager", "FailoverController",
    "ShardManager", "CrossNodeQuery",
]

DISTRIBUTED_IMPORT_PATTERNS = [
    "raft", "paxos", "consensus", "distributed_lock",
    "etcd", "zookeeper", "serf", "memberlist",
]

def test_no_distributed_types_outside_feature_gate():
    """
    Scan all modules and verify that distributed system types are not
    defined or referenced outside a feature-gated clustering module.
    """
    all_modules = find_all_modules("src/")
    for module in all_modules:
        if is_feature_gated(module, "clustering"):
            continue  # Feature-gated modules are allowed
        defined_types = get_defined_types(module)
        for type_name in defined_types:
            for pattern in DISTRIBUTED_TYPE_PATTERNS:
                assert pattern.lower() not in type_name.lower(), (
                    f"{module} defines {type_name} which matches distributed "
                    f"pattern {pattern}. V1 is single-node only. (ADR-003, ADR-005)"
                )

def test_no_distributed_library_imports():
    """
    Verify that no source module imports distributed systems libraries
    unless it is behind a feature gate.
    """
    all_modules = find_all_modules("src/")
    for module in all_modules:
        if is_feature_gated(module, "clustering"):
            continue
        imports = get_imports(module)
        for imp in imports:
            for pattern in DISTRIBUTED_IMPORT_PATTERNS:
                assert pattern not in imp.lower(), (
                    f"{module} imports {imp} which appears to be a distributed "
                    f"systems library. V1 is single-node only. (ADR-003)"
                )

def test_single_node_transaction_model():
    """
    Verify that transaction implementations do not reference remote nodes,
    distributed coordination, or cross-node semantics.
    """
    txn_modules = find_all_modules("src/domain/**/transaction/")
    txn_modules += find_all_modules("src/infrastructure/**/transaction/")
    for module in txn_modules:
        source = read_source(module)
        assert "remote_node" not in source.lower(), (
            f"{module} references remote nodes in transaction code. "
            f"V1 transactions are local only. (ADR-005)"
        )
        assert "distributed" not in source.lower() or has_override(source, "ADR-005"), (
            f"{module} uses 'distributed' in transaction code. "
            f"V1 transactions are local only. (ADR-005)"
        )
