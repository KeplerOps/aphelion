# Architecture Test: Server Layer Required (ADR-007)
#
# Rule: All public-facing functions must be in the src/api/ layer,
#        not directly in src/infrastructure/engine/.
#
# Rationale: ADR-007 requires the product to be exposed as a server process
#            with a product-owned external interface. The raw embedded kernel
#            API is an internal implementation detail.
#
# See: docs/adr-enforcement.md, docs/adrs/ADR-007.md

# Pseudocode — convert to chosen framework when tech stack is selected.

def test_no_public_endpoints_in_engine_layer():
    """
    Verify that src/infrastructure/engine/ does not define HTTP routes,
    RPC endpoints, or other public-facing interfaces.
    """
    engine_modules = find_all_modules("src/infrastructure/engine/")
    for module in engine_modules:
        decorators = get_decorators(module)
        for dec in decorators:
            assert dec not in ["@route", "@endpoint", "@rpc", "@api", "@controller"], (
                f"{module} defines a public endpoint ({dec}) in the engine layer. "
                f"Public interfaces belong in src/api/. (ADR-007)"
            )

def test_api_layer_mediates_all_external_access():
    """
    Verify that the API layer exists and defines the product's external
    interface, with auth/audit/observability middleware attached.
    """
    api_modules = find_all_modules("src/api/")
    assert len(api_modules) > 0, (
        "No modules found in src/api/. The product must expose a server "
        "interface through the API layer. (ADR-007)"
    )

    for module in api_modules:
        # Check that middleware is applied (auth, audit, observability)
        middleware = get_applied_middleware(module)
        route_handlers = get_route_handlers(module)
        for handler in route_handlers:
            assert "auth" in [m.name.lower() for m in handler.middleware], (
                f"{handler.qualified_name} has no auth middleware. "
                f"All external endpoints must have auth at the server layer. (ADR-007)"
            )

def test_engine_types_not_exported_publicly():
    """
    Verify that the package's public API surface does not re-export
    types from src/infrastructure/engine/.
    """
    public_exports = get_public_exports("src/")
    engine_types = find_exported_types("src/infrastructure/engine/")
    for export in public_exports:
        assert export.type_origin not in engine_types, (
            f"Public export {export.name} originates from the engine layer. "
            f"The raw kernel API must not be the product contract. (ADR-007)"
        )
